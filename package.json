{
  "name": "hermes-agent-registry",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npx vite",
    "dev:backend": "cd backend && npx tsx watch src/index.ts",
